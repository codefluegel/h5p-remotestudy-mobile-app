{
  "name": "h5p-mobile-backend",
  "version": "0.0.1",
  "description": "node part of the project",
  "main": "main.js",
  "exports": {
    ".": "./main.js",
    "./serverApplication": "./build/serverApplication.js"
  },
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p .",
    "start": "node build/main.js",
    "start:dev": "ts-node src/main.ts",
    "start:dev:watch": "nodemon --exec \"ts-node\" src/main.ts",
    "install-without-dev-deps": "npm ci --omit=dev",
    "postinstall": "patch-package && rimraf node_modules/@node-rs",
    "copy-additional-ca-file": "node copy-ca-file.js"
  },
  "dependencies": {
    "@lumieducation/h5p-express": "^10.0.4",
    "@lumieducation/h5p-server": "^10.0.4",
    "axios": "^1.8.4",
    "crc-32": "^1.2.2",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "patch-package": "^8.0.0",
    "rimraf": "^5.0.10",
    "tmp-promise": "^3.0.3",
    "yauzl-promise": "^4.0.0"
  },
  "devDependencies": {
    "@tsconfig/node18": "^18.2.4",
    "@types/express": "^4.17.21",
    "@types/express-fileupload": "^1.5.1",
    "@types/yauzl-promise": "^4.0.1",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2"
  }
}
